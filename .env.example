# Copia este archivo como `.env` en la raíz del proyecto (local).
# En producción (Vercel, Netlify, etc.) configura las mismas variables
# en el panel de Environment Variables — NO subas .env a GitHub.

# URL del proyecto Supabase → Settings → API → Project URL
VITE_SUPABASE_URL=https://tu-proyecto.supabase.co

# Clave pública (anon) → Settings → API → anon public
# Es segura en el frontend; el acceso real lo controla Row Level Security (RLS).
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# UUID del restaurante en la tabla `restaurants`
# Puedes obtenerlo en Supabase → Table Editor → restaurants → columna id
VITE_RESTAURANT_ID=00000000-0000-0000-0000-000000000000
